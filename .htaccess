# ============================================================
#  ESP Campagne 2026 вЂ” SГ©curitГ© Serveur Apache
# ============================================================

# в”Ђв”Ђ HTTPS forcГ© в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# в”Ђв”Ђ En-tГЄtes de sГ©curitГ© HTTP в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_headers.c>
  # EmpГЄche le sniffing de type MIME
  Header always set X-Content-Type-Options "nosniff"

  # Protection clickjacking
  Header always set X-Frame-Options "DENY"

  # Protection XSS navigateurs anciens
  Header always set X-XSS-Protection "1; mode=block"

  # Politique rГ©fГ©rent stricte
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # DГ©sactiver les APIs navigateur inutiles
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

  # HSTS (forcer HTTPS pendant 1 an)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content Security Policy
  Header always set Content-Security-Policy "default-src 'self'; \
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
    font-src https://fonts.gstatic.com; \
    img-src 'self' data: blob:; \
    script-src 'self'; \
    connect-src 'self' https://formspree.io; \
    frame-ancestors 'none'; \
    base-uri 'self'; \
    form-action 'self' https://formspree.io; \
    object-src 'none'; \
    upgrade-insecure-requests;"

  # Supprimer les en-tГЄtes rГ©vГ©lant la technologie
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# в”Ђв”Ђ Masquer les informations serveur в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ServerTokens Prod
ServerSignature Off

# в”Ђв”Ђ Interdire la navigation dans les dossiers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
Options -Indexes -MultiViews

# в”Ђв”Ђ Bloquer l'accГЁs aux fichiers sensibles в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<FilesMatch "(^\.htaccess|^\.htpasswd|^\.env|\.log$|\.sql$|\.bak$|\.config$|\.ini$|\.sh$)">
  Order allow,deny
  Deny from all
</FilesMatch>

# в”Ђв”Ђ Bloquer les mГ©thodes HTTP dangereuses в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|DELETE|PUT|PATCH)$ [NC]
  RewriteRule .* - [F,L]
</IfModule>

# в”Ђв”Ђ Bloquer les tentatives d'injection SQL dans l'URL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
  RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|delete.*from|drop\s+table|alter\s+table|exec\s*\(|execute\s*\() [NC,OR]
  RewriteCond %{QUERY_STRING} (benchmark|sleep|waitfor|pg_sleep) [NC,OR]
  RewriteCond %{REQUEST_URI} (\.\./|\.\.\\) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# в”Ђв”Ђ Bloquer les tentatives XSS dans l'URL в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
  RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=|onclick=) [NC,OR]
  RewriteCond %{QUERY_STRING} (%3Cscript|%3C%2Fscript|%22%3E%3Cscript) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# в”Ђв”Ђ Bloquer les User-Agents malveillants в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (masscan|sqlmap|nikto|nmap|havij|acunetix|netsparker|w3af|skipfish|burpsuite|openvas) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# в”Ђв”Ђ Limiter la taille des requГЄtes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
LimitRequestBody 1048576

# в”Ђв”Ђ Cache des assets statiques в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# в”Ђв”Ђ Compression Gzip в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json text/xml
</IfModule>

# в”Ђв”Ђ Page d'erreur personnalisГ©e в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
